# App
PORT=3000
NODE_ENV=development

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=deltra
DB_PORT=5432
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/deltra?schema=public"

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# SMTP (email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM="Deltra <noreply@deltra.id>"

# MinIO (object storage)
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_USER=deltra
MINIO_PASSWORD=deltra123
MINIO_BUCKET=deltra-uploads
