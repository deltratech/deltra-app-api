{
  "name": "deltra-app-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && npm run copy:tenant-engine",
    "copy:tenant-engine": "mkdir -p dist/generated/tenant-client && cp src/generated/tenant-client/libquery_engine-* dist/generated/tenant-client/ 2>/dev/null || true",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build api",
    "docker:dev:logs": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f api",
    "docker:dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml stop api",
    "db:bootstrap": "node scripts/bootstrap-db.js",
    "prisma:migrate:tenant": "prisma migrate dev --schema=prisma/tenant/schema.prisma",
    "prisma:generate:tenant": "prisma generate --schema=prisma/tenant/schema.prisma",
    "seed:platform": "ts-node --project tsconfig.seed.json prisma/seed.ts",
    "seed:tenant": "ts-node --project tsconfig.seed.json prisma/tenant/seed.ts",
    "seed:tenant:schools": "ts-node --project tsconfig.seed.json prisma/tenant/seed-schools.ts",
    "seed:tenant:attendance-feature": "ts-node --project tsconfig.seed.json prisma/tenant/seed-attendance-feature.ts",
    "seed:tenant:contract-templates": "ts-node --project tsconfig.seed.json prisma/tenant/seed-contract-templates.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",
    "@aws-sdk/s3-request-presigner": "^3.1052.0",
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@bull-board/nestjs": "^7.1.5",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.3",
    "@prisma/client": "^6.19.3",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parse": "^6.2.1",
    "docxtemplater": "^3.68.7",
    "docxtemplater-image-module-free": "^1.1.1",
    "exceljs": "^4.4.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "pizzip": "^3.2.0",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pizzip": "^3.0.5",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
