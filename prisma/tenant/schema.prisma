// ============================================================================
// LMS Multi-Tenant SaaS — Tenant Schema (tenant_xxx)
// ----------------------------------------------------------------------------
// Deployed into each tenant's own PostgreSQL schema via prisma migrate deploy.
// Every table here is fully scoped to one school — complete isolation.
// Auth flow: resolve tenant from subdomain → look up user in THIS schema.
// ============================================================================

generator tenantClient {
  provider      = "prisma-client-js"
  output        = "../../src/generated/tenant-client"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  school_admin
  network_admin
  principal
  finance
  teacher
  student
  admission

  @@map("user_role")
}

enum UserStatus {
  active
  inactive
  suspended

  @@map("user_status")
}

enum StudentStatus {
  active
  alumni
  transferred
  withdrawn

  @@map("student_status")
}

enum EnrollmentStatus {
  active
  transferred
  graduated
  dropped

  @@map("enrollment_status")
}

enum AttendanceStatus {
  present
  late
  excused
  sick
  absent

  @@map("attendance_status")
}

enum Gender {
  male
  female

  @@map("gender")
}

enum TeacherStatus {
  active
  inactive

  @@map("teacher_status")
}

enum EmploymentStatus {
  pns
  p3k
  tetap
  honorer

  @@map("employment_status")
}

enum TeacherContractTemplateType {
  guru_tetap
  guru_honorer
  staff

  @@map("teacher_contract_template_type")
}

enum TeacherContractStatus {
  draft
  pending_signature
  active
  expired
  renewed

  @@map("teacher_contract_status")
}

enum PortfolioType {
  project
  extracurricular
  certificate
  personal_development
  other

  @@map("portfolio_type")
}

enum AchievementCategory {
  academic
  non_academic
  sports
  arts
  organization
  competition

  @@map("achievement_category")
}

enum AchievementLevel {
  school
  district
  city
  provincial
  national
  international

  @@map("achievement_level")
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday

  @@map("day_of_week")
}

enum ScheduleStatus {
  draft
  published
  archived

  @@map("schedule_status")
}

enum PeriodKind {
  lesson
  recess
  break

  @@map("period_kind")
}


// ============================================================================
// IDENTITY & ACCESS
// ============================================================================

/// All user accounts for this school — admin, finance, principal, teacher, student.
/// Authentication always resolves tenant from subdomain first, then looks here.
model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String?    @unique
  username     String?    @unique
  phone        String?
  passwordHash String?    @map("password_hash")
  fullName     String     @map("full_name")
  avatarUrl    String?    @map("avatar_url")
  role         UserRole
  status       UserStatus @default(active)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt      @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?                  @map("deleted_at") @db.Timestamptz(6)

  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  attendanceRecords AttendanceRecord[]

  @@map("users")
}

// ============================================================================
// ROLE-SPECIFIC PROFILES
// ============================================================================

/// Student-specific data. One-to-one with User where role = student.
/// tenantId omitted — schema-level isolation already scopes every row to this school.
model StudentProfile {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @unique @map("user_id") @db.Uuid
  nisn       String?   @unique                      // Nomor Induk Siswa Nasional
  nik        String?   @unique                      // Nomor Induk Kependudukan
  birthDate  DateTime?                @map("birth_date")  @db.Date
  birthPlace String?                  @map("birth_place")
  gender     Gender?
  religion   String?
  address    String?
  phone      String?
  photoUrl   String?                  @map("photo_url")
  entryYear  Int?                     @map("entry_year")  @db.SmallInt
  status     StudentStatus            @default(active)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt      @map("updated_at") @db.Timestamptz(6)

  user         User                 @relation(fields: [userId], references: [id])
  enrollments  Enrollment[]
  guardians    Guardian[]
  portfolios   StudentPortfolio[]
  achievements StudentAchievement[]
  attendanceRecords AttendanceRecord[]

  @@map("student_profiles")
}

/// Wali murid / guardian. One student can have multiple guardians.
model Guardian {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId String   @map("student_profile_id") @db.Uuid
  name             String
  relationship     String?
  phone            String?
  email            String?
  address          String?
  isPrimary        Boolean  @default(false) @map("is_primary")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt      @map("updated_at") @db.Timestamptz(6)

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])

  @@map("guardians")
}

/// Teacher-specific data. One-to-one with User where role = teacher.
model TeacherProfile {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String           @unique          @map("user_id")          @db.Uuid
  nuptk            String?
  nik              String?          @unique
  birthDate        DateTime?                         @map("birth_date")       @db.Date
  birthPlace       String?                           @map("birth_place")
  gender           Gender?
  religion         String?
  phone            String?
  email            String?
  employmentStatus EmploymentStatus?                 @map("employment_status")
  photoUrl         String?                           @map("photo_url")
  bio              String?
  status           TeacherStatus    @default(active)
  createdAt        DateTime         @default(now())  @map("created_at")       @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt       @map("updated_at")       @db.Timestamptz(6)
  deletedAt        DateTime?                         @map("deleted_at")       @db.Timestamptz(6)

  user          User                  @relation(fields: [userId], references: [id])
  classSubjects ClassSubject[]
  scheduleEntries ScheduleEntry[]
  requirements  ScheduleRequirement[]
  unavailability TeacherUnavailability[]
  contracts     TeacherContract[]
  homeroomAssignments HomeroomAssignment[]

  @@map("teacher_profiles")
}

model TeacherContract {
  id                        String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherProfileId          String                      @map("teacher_profile_id") @db.Uuid
  templateId                String?                     @map("template_id") @db.Uuid
  templateType              TeacherContractTemplateType @map("template_type")
  status                    TeacherContractStatus       @default(draft)
  contractStartDate         DateTime                    @map("contract_start_date") @db.Date
  contractEndDate           DateTime                    @map("contract_end_date") @db.Date
  employmentStatus          EmploymentStatus?           @map("employment_status")
  teachingAssignmentNotes   String?                     @map("teaching_assignment_notes")
  documentTitle             String?                     @map("document_title")
  fileUrl                   String                      @map("file_url")
  fileName                  String                      @map("file_name")
  mimeType                  String                      @map("mime_type")
  sizeBytes                 Int                         @map("size_bytes")
  signedAt                  DateTime?                   @map("signed_at") @db.Timestamptz(6)
  eSignature                String?                     @map("e_signature")
  notes                     String?
  renderedContent           String?                     @map("rendered_content")
  renewalReminderAt         DateTime?                   @map("renewal_reminder_at") @db.Timestamptz(6)
  createdByUserId           String?                     @map("created_by_user_id") @db.Uuid
  updatedByUserId           String?                     @map("updated_by_user_id") @db.Uuid
  createdAt                 DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                 DateTime?                   @map("deleted_at") @db.Timestamptz(6)

  teacher  TeacherProfile         @relation(fields: [teacherProfileId], references: [id])
  template TeacherContractTemplate? @relation(fields: [templateId], references: [id])

  @@index([teacherProfileId])
  @@index([templateType])
  @@index([status])
  @@index([contractStartDate, contractEndDate])
  @@map("teacher_contracts")
}

model TeacherContractTemplate {
  id           String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  templateType TeacherContractTemplateType @map("template_type")
  variablesJson Json?                      @map("variables_json") @db.JsonB
  templateFileUrl String?                   @map("template_file_url")
  templateFileName String?                  @map("template_file_name")
  templateMimeType String?                  @map("template_mime_type")
  templateSizeBytes Int?                    @map("template_size_bytes")
  version      Int                         @default(1)
  isActive     Boolean                     @default(true) @map("is_active")
  createdAt    DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?                   @map("deleted_at") @db.Timestamptz(6)

  contracts TeacherContract[]

  @@index([templateType, isActive])
  @@map("teacher_contract_templates")
}

// ============================================================================
// ACADEMIC STRUCTURE
// ============================================================================

/// Rombel / kelas (e.g. "X IPA 1" semester 1 T.A. 2025/2026).
model Classroom {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  gradeLevel     Int       @map("grade_level") @db.SmallInt
  academicYear   String    @map("academic_year")
  semester       Int       @db.SmallInt
  homeroomUserId String?   @map("homeroom_user_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt      @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?                 @map("deleted_at") @db.Timestamptz(6)

  enrollments   Enrollment[]
  classSubjects ClassSubject[]
  schedules     Schedule[]
  requirements  ScheduleRequirement[]
  homeroomAssignments HomeroomAssignment[]
  attendanceRecords AttendanceRecord[]

  @@unique([name, academicYear, semester])
  @@map("classrooms")
}

model PeriodTemplate {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gradeLevel   Int      @map("grade_level") @db.SmallInt
  academicYear String   @map("academic_year")
  dayStart     String   @map("day_start")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rows       PeriodRow[]

  @@unique([gradeLevel, academicYear])
  @@map("period_templates")
}

model PeriodRow {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId  String     @map("template_id") @db.Uuid
  sortOrder   Int        @map("sort_order")
  kind        PeriodKind
  label       String
  durationMin Int        @map("duration_min")
  activeDays  Int[]      @default([]) @map("active_days")

  template PeriodTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  entries  ScheduleEntry[]
  unavailability TeacherUnavailability[]

  @@unique([templateId, sortOrder])
  @@map("period_rows")
}

model HomeroomAssignment {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classroomId      String    @map("classroom_id") @db.Uuid
  teacherProfileId String    @map("teacher_profile_id") @db.Uuid
  academicYear     String    @map("academic_year")
  semester         Int       @db.SmallInt
  isActive         Boolean   @default(true) @map("is_active")
  assignedAt       DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)
  endedAt          DateTime? @map("ended_at") @db.Timestamptz(6)
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  classroom Classroom      @relation(fields: [classroomId], references: [id])
  teacher   TeacherProfile @relation(fields: [teacherProfileId], references: [id])

  @@index([teacherProfileId, isActive])
  @@index([classroomId, academicYear, semester])
  @@map("homeroom_assignments")
}

/// Mata pelajaran milik sekolah ini.
model Subject {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String?
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt      @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?                 @map("deleted_at") @db.Timestamptz(6)

  classSubjects ClassSubject[]
  portfolios    StudentPortfolio[]
  scheduleEntries ScheduleEntry[]
  requirements  ScheduleRequirement[]

  @@map("subjects")
}

/// Penugasan guru ke kelas + mata pelajaran.
model ClassSubject {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classroomId      String         @map("classroom_id")       @db.Uuid
  subjectId        String         @map("subject_id")         @db.Uuid
  teacherProfileId String?        @map("teacher_profile_id") @db.Uuid

  classroom Classroom       @relation(fields: [classroomId],      references: [id])
  subject   Subject         @relation(fields: [subjectId],         references: [id])
  teacher   TeacherProfile? @relation(fields: [teacherProfileId], references: [id])

  @@unique([classroomId, subjectId])
  @@map("class_subjects")
}

/// Siswa masuk ke kelas.
model Enrollment {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId String           @map("student_profile_id") @db.Uuid
  classroomId      String           @map("classroom_id")       @db.Uuid
  enrolledAt       DateTime         @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  status           EnrollmentStatus @default(active)

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])
  classroom      Classroom      @relation(fields: [classroomId],      references: [id])

  @@unique([studentProfileId, classroomId])
  @@map("enrollments")
}

model AttendanceRecord {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId String           @map("student_profile_id") @db.Uuid
  classroomId      String           @map("classroom_id") @db.Uuid
  attendanceDate   DateTime         @map("attendance_date") @db.Date
  status           AttendanceStatus
  notes            String?
  markedByUserId   String?          @map("marked_by_user_id") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz(6)

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])
  classroom      Classroom      @relation(fields: [classroomId], references: [id])
  markedBy       User?          @relation(fields: [markedByUserId], references: [id])

  @@unique([studentProfileId, classroomId, attendanceDate])
  @@index([classroomId, attendanceDate])
  @@index([studentProfileId, attendanceDate])
  @@map("attendance_records")
}

// ============================================================================
// STUDENT PORTFOLIO & ACHIEVEMENTS
// ============================================================================

/// Portfolio entries: projects, extracurriculars, certificates, personal development.
model StudentPortfolio {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId String        @map("student_profile_id") @db.Uuid
  title            String
  type             PortfolioType
  description      String?
  subjectId        String?       @map("subject_id") @db.Uuid
  startDate        DateTime?     @map("start_date") @db.Date
  endDate          DateTime?     @map("end_date")   @db.Date
  createdAt        DateTime      @default(now())    @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt         @map("updated_at") @db.Timestamptz(6)

  studentProfile StudentProfile       @relation(fields: [studentProfileId], references: [id])
  subject        Subject?             @relation(fields: [subjectId],        references: [id])
  attachments    PortfolioAttachment[]

  @@map("student_portfolios")
}

model PortfolioAttachment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  portfolioId String   @map("portfolio_id") @db.Uuid
  fileUrl     String   @map("file_url")
  fileName    String   @map("file_name")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  portfolio StudentPortfolio @relation(fields: [portfolioId], references: [id])

  @@map("portfolio_attachments")
}

/// Academic and non-academic achievements with level and organizer info.
model StudentAchievement {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId String              @map("student_profile_id") @db.Uuid
  title            String
  category         AchievementCategory
  level            AchievementLevel?
  description      String?
  organizer        String?
  eventName        String?             @map("event_name")
  achievedAt       DateTime            @map("achieved_at") @db.Date
  rank             String?
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime            @updatedAt      @map("updated_at") @db.Timestamptz(6)

  studentProfile StudentProfile          @relation(fields: [studentProfileId], references: [id])
  attachments    AchievementAttachment[]

  @@map("student_achievements")
}

model AchievementAttachment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  achievementId String   @map("achievement_id") @db.Uuid
  fileUrl       String   @map("file_url")
  fileName      String   @map("file_name")
  mimeType      String   @map("mime_type")
  sizeBytes     Int      @map("size_bytes")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  achievement StudentAchievement @relation(fields: [achievementId], references: [id])

  @@map("achievement_attachments")
}

// ============================================================================
// SCHEDULING
// ============================================================================

/// Physical rooms available for scheduling.
model Room {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique
  capacity    Int?
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt      @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?                 @map("deleted_at") @db.Timestamptz(6)

  scheduleEntries ScheduleEntry[]
  requirements ScheduleRequirement[]

  @@map("rooms")
}

/// Configurable lesson periods (e.g. 07:00–07:45).
/// Per-class-per-term timetable document.
model Schedule {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classroomId          String         @map("classroom_id") @db.Uuid
  academicYear         String         @map("academic_year")
  semester             Int            @db.SmallInt
  status               ScheduleStatus @default(draft)
  publishedAt          DateTime?      @map("published_at") @db.Timestamptz(6)
  archivedAt           DateTime?      @map("archived_at") @db.Timestamptz(6)
  copiedFromScheduleId String?        @map("copied_from_schedule_id") @db.Uuid
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?      @map("deleted_at") @db.Timestamptz(6)

  classroom Classroom @relation(fields: [classroomId], references: [id])
  copiedFrom Schedule? @relation("CopiedSchedule", fields: [copiedFromScheduleId], references: [id])
  copies     Schedule[] @relation("CopiedSchedule")
  entries    ScheduleEntry[]

  @@unique([classroomId, academicYear, semester])
  @@map("schedules")
}

model ScheduleEntry {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId       String   @map("schedule_id") @db.Uuid
  subjectId        String   @map("subject_id") @db.Uuid
  teacherProfileId String   @map("teacher_profile_id") @db.Uuid
  roomId           String   @map("room_id") @db.Uuid
  dayOfWeek        Int?     @map("day_of_week") @db.SmallInt
  periodRowId      String?  @map("period_row_id") @db.Uuid
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  schedule  Schedule       @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  subject   Subject        @relation(fields: [subjectId], references: [id])
  teacher   TeacherProfile @relation(fields: [teacherProfileId], references: [id])
  room      Room           @relation(fields: [roomId], references: [id])
  periodRow PeriodRow?     @relation(fields: [periodRowId], references: [id])

  @@index([teacherProfileId, dayOfWeek, periodRowId])
  @@index([roomId, dayOfWeek, periodRowId])
  @@map("schedule_entries")
}

// ============================================================================
// AUTO-SCHEDULING INPUTS
// ============================================================================

/// Defines how many sessions per week a subject needs in a class.
/// This is the input consumed by the greedy auto-scheduler.
model ScheduleRequirement {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classroomId      String   @map("classroom_id")       @db.Uuid
  subjectId        String   @map("subject_id")         @db.Uuid
  teacherProfileId String?  @map("teacher_profile_id") @db.Uuid
  roomId           String?  @map("room_id")            @db.Uuid
  sessionsPerWeek  Int      @map("sessions_per_week")  @db.SmallInt
  academicYear     String   @map("academic_year")
  semester         Int      @db.SmallInt
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt      @map("updated_at") @db.Timestamptz(6)

  classroom Classroom       @relation(fields: [classroomId],      references: [id])
  subject   Subject         @relation(fields: [subjectId],        references: [id])
  teacher   TeacherProfile? @relation(fields: [teacherProfileId], references: [id])
  room      Room?           @relation(fields: [roomId],           references: [id])

  @@unique([classroomId, subjectId, academicYear, semester])
  @@map("schedule_requirements")
}

/// Teacher unavailability — slots where teacher CANNOT be assigned.
model TeacherUnavailability {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherProfileId String    @map("teacher_profile_id") @db.Uuid
  dayOfWeek        Int       @map("day_of_week") @db.SmallInt
  periodRowId      String    @map("period_row_id") @db.Uuid
  reason           String?
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  teacher  TeacherProfile @relation(fields: [teacherProfileId], references: [id])
  periodRow PeriodRow     @relation(fields: [periodRowId], references: [id])

  @@unique([teacherProfileId, dayOfWeek, periodRowId])
  @@map("teacher_unavailability")
}
