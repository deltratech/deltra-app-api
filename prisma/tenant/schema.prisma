// ============================================================================
// LMS Multi-Tenant SaaS — Tenant Schema (tenant_xxx)
// ----------------------------------------------------------------------------
// Deployed into each tenant's own PostgreSQL schema via prisma migrate deploy.
// Every table here is fully scoped to one school — complete isolation.
// Auth flow: resolve tenant from subdomain → look up user in THIS schema.
// ============================================================================

generator tenantClient {
  provider      = "prisma-client-js"
  output        = "../../src/generated/tenant-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  school_admin
  network_admin
  principal
  finance
  teacher
  student
  parent
  admission

  @@map("user_role")
}

enum UserStatus {
  active
  inactive
  suspended

  @@map("user_status")
}

enum StudentStatus {
  active
  alumni
  transferred
  withdrawn

  @@map("student_status")
}

enum EnrollmentStatus {
  active
  transferred
  graduated
  dropped

  @@map("enrollment_status")
}

enum AttendanceStatus {
  present
  late
  excused
  sick
  absent

  @@map("attendance_status")
}

enum Gender {
  male
  female

  @@map("gender")
}

enum TeacherStatus {
  active
  inactive

  @@map("teacher_status")
}

enum EmploymentStatus {
  pns
  p3k
  tetap
  honorer

  @@map("employment_status")
}

enum ContractStatus {
  draft
  pending_signature
  pending_approval
  approved
  rejected
  active
  archived
  expired
  renewed

  @@map("teacher_contract_status")
}

/// Categories of official school documents (SK / Surat). Workflow rules per
/// category live in code (document-categories.ts), not in the DB.
enum DocumentCategory {
  kontrak_guru_pkwt
  kontrak_staff
  pkwtt
  perpanjangan_kontrak
  sk_tugas_mengajar
  sk_wali_kelas
  sk_pembina_ekskul
  sk_wakasek
  sk_koordinator_kurikulum
  sk_koordinator
  sk_kepala_sekolah
  sk_guru_tetap
  sk_guru_kontrak
  sk_staff_tetap
  sk_staff_kontrak

  @@map("document_category")
}

enum PortfolioType {
  project
  extracurricular
  certificate
  personal_development
  other

  @@map("portfolio_type")
}

enum AchievementCategory {
  academic
  non_academic
  sports
  arts
  organization
  competition

  @@map("achievement_category")
}

enum AchievementLevel {
  school
  district
  city
  provincial
  national
  international

  @@map("achievement_level")
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday

  @@map("day_of_week")
}

enum ScheduleStatus {
  draft
  published
  archived

  @@map("schedule_status")
}

enum AnnouncementAudienceType {
  school
  grade
  class

  @@map("announcement_audience_type")
}

enum AnnouncementChannel {
  in_app
  whatsapp
  email

  @@map("announcement_channel")
}

enum AnnouncementStatus {
  draft
  scheduled
  sent
  cancelled

  @@map("announcement_status")
}

enum AnnouncementDeliveryStatus {
  pending
  queued
  sent
  failed

  @@map("announcement_delivery_status")
}

enum AnnouncementTemplateCategory {
  school_holiday
  parent_meeting
  exam

  @@map("announcement_template_category")
}

enum PushDevicePlatform {
  web

  @@map("push_device_platform")
}

enum NotificationDeliveryStatus {
  queued
  sent
  failed

  @@map("notification_delivery_status")
}

enum NotificationCategory {
  academic
  announcement
  attendance
  finance
  document
  system

  @@map("notification_category")
}

enum NotificationPriority {
  low
  normal
  high
  urgent

  @@map("notification_priority")
}

enum NotificationSourceType {
  schedule
  announcement
  attendance
  invoice
  contract
  academic_note
  system

  @@map("notification_source_type")
}

enum PeriodKind {
  lesson
  recess
  break

  @@map("period_kind")
}

// ============================================================================
// IDENTITY & ACCESS
// ============================================================================

/// All user accounts for this school — admin, finance, principal, teacher, student.
/// Authentication always resolves tenant from subdomain first, then looks here.
model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String?    @unique
  username     String?    @unique
  phone        String?
  passwordHash String?    @map("password_hash")
  fullName     String     @map("full_name")
  avatarUrl    String?    @map("avatar_url")
  signatureData String?   @map("signature_data")
  contractApprover Boolean @default(false) @map("contract_approver")
  role         UserRole
  status       UserStatus @default(active)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)

  studentProfile         StudentProfile?
  teacherProfile         TeacherProfile?
  guardianAccounts       Guardian[]
  attendanceRecords      AttendanceRecord[]
  attendanceRecordsUpdated AttendanceRecord[]     @relation("AttendanceUpdatedBy")
  announcementsCreated   Announcement[]          @relation("AnnouncementCreatedBy")
  announcementAuditLogs  AnnouncementAuditLog[]
  announcementRecipients AnnouncementRecipient[]
  pushDeviceTokens       PushDeviceToken[]
  notificationRecipients NotificationRecipient[]
  academicNotesCreated AcademicNote[] @relation("AcademicNoteCreatedBy")
  receivedContracts Contract[] @relation("ContractRecipient")

  @@map("users")
}

// ============================================================================
// ROLE-SPECIFIC PROFILES
// ============================================================================

/// Student-specific data. One-to-one with User where role = student.
/// tenantId omitted — schema-level isolation already scopes every row to this school.
model StudentProfile {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String        @unique @map("user_id") @db.Uuid
  nisn       String?       @unique // Nomor Induk Siswa Nasional
  nik        String?       @unique // Nomor Induk Kependudukan
  birthDate  DateTime?     @map("birth_date") @db.Date
  birthPlace String?       @map("birth_place")
  gender     Gender?
  religion   String?
  address    String?
  phone      String?
  photoUrl   String?       @map("photo_url")
  entryYear  Int?          @map("entry_year") @db.SmallInt
  status     StudentStatus @default(active)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user                   User                    @relation(fields: [userId], references: [id])
  enrollments            Enrollment[]
  guardians              Guardian[]
  portfolios             StudentPortfolio[]
  achievements           StudentAchievement[]
  academicNotes          AcademicNote[]
  attendanceRecords      AttendanceRecord[]
  announcementRecipients AnnouncementRecipient[]

  @@map("student_profiles")
}

/// Wali murid / guardian. One student can have multiple guardians.
model Guardian {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId String   @map("student_profile_id") @db.Uuid
  userId           String?  @map("user_id") @db.Uuid
  name             String
  relationship     String?
  phone            String?
  email            String?
  address          String?
  isPrimary        Boolean  @default(false) @map("is_primary")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  studentProfile         StudentProfile          @relation(fields: [studentProfileId], references: [id])
  user                   User?                   @relation(fields: [userId], references: [id])
  announcementRecipients AnnouncementRecipient[]

  @@index([userId])
  @@map("guardians")
}

/// Teacher-specific data. One-to-one with User where role = teacher.
model TeacherProfile {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String            @unique @map("user_id") @db.Uuid
  nuptk            String?
  nik              String?           @unique
  birthDate        DateTime?         @map("birth_date") @db.Date
  birthPlace       String?           @map("birth_place")
  gender           Gender?
  religion         String?
  phone            String?
  email            String?
  employmentStatus EmploymentStatus? @map("employment_status")
  photoUrl         String?           @map("photo_url")
  bio              String?
  status           TeacherStatus     @default(active)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz(6)

  user                User                    @relation(fields: [userId], references: [id])
  classSubjects       ClassSubject[]
  scheduleEntries     ScheduleEntry[]
  requirements        ScheduleRequirement[]
  unavailability      TeacherUnavailability[]
  contracts           Contract[]
  homeroomAssignments HomeroomAssignment[]
  academicNotes       AcademicNote[]

  @@map("teacher_profiles")
}

model Contract {
  id                        String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherProfileId          String?                     @map("teacher_profile_id") @db.Uuid
  recipientUserId           String?                     @map("recipient_user_id") @db.Uuid
  templateId                String?                     @map("template_id") @db.Uuid
  category                  DocumentCategory?
  recipientType             String?                     @map("recipient_type")
  approverRolesJson         Json?                       @map("approver_roles_json") @db.JsonB
  signaturesJson            Json?                       @map("signatures_json") @db.JsonB
  status                    ContractStatus       @default(draft)
  contractStartDate         DateTime                    @map("contract_start_date") @db.Date
  contractEndDate           DateTime?                   @map("contract_end_date") @db.Date
  employmentStatus          EmploymentStatus?           @map("employment_status")
  teachingAssignmentNotes   String?                     @map("teaching_assignment_notes")
  documentTitle             String?                     @map("document_title")
  payloadJson               Json?                       @map("payload_json") @db.JsonB
  fileUrl                   String                      @map("file_url")
  fileName                  String                      @map("file_name")
  mimeType                  String                      @map("mime_type")
  sizeBytes                 Int                         @map("size_bytes")
  approverUserId            String?                     @map("approver_user_id") @db.Uuid
  approvedAt                DateTime?                   @map("approved_at") @db.Timestamptz(6)
  rejectedAt                DateTime?                   @map("rejected_at") @db.Timestamptz(6)
  rejectReason              String?                     @map("reject_reason")
  signerUserId              String?                     @map("signer_user_id") @db.Uuid
  signedAt                  DateTime?                   @map("signed_at") @db.Timestamptz(6)
  eSignature                String?                     @map("e_signature")
  notes                     String?
  renderedContent           String?                     @map("rendered_content")
  renewalReminderAt         DateTime?                   @map("renewal_reminder_at") @db.Timestamptz(6)
  createdByUserId           String?                     @map("created_by_user_id") @db.Uuid
  updatedByUserId           String?                     @map("updated_by_user_id") @db.Uuid
  createdAt                 DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                 DateTime?                   @map("deleted_at") @db.Timestamptz(6)

  teacher  TeacherProfile?        @relation(fields: [teacherProfileId], references: [id])
  recipientUser User?             @relation("ContractRecipient", fields: [recipientUserId], references: [id])
  template ContractTemplate? @relation(fields: [templateId], references: [id])

  @@index([teacherProfileId])
  @@index([recipientUserId])
  @@index([status])
  @@index([category])
  @@index([contractStartDate, contractEndDate])
  @@map("contracts")
}

model ContractTemplate {
  id           String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  category     DocumentCategory?
  recipientType String?                    @map("recipient_type")
  approverRolesJson Json?                  @map("approver_roles_json") @db.JsonB
  variablesJson Json?                      @map("variables_json") @db.JsonB
  signatureSlotsJson Json?                 @map("signature_slots_json") @db.JsonB
  templateFileUrl String?                   @map("template_file_url")
  templateFileName String?                  @map("template_file_name")
  templateMimeType String?                  @map("template_mime_type")
  templateSizeBytes Int?                    @map("template_size_bytes")
  version      Int                         @default(1)
  isActive     Boolean                     @default(true) @map("is_active")
  createdAt    DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?                   @map("deleted_at") @db.Timestamptz(6)

  contracts Contract[]

  @@index([isActive])
  @@map("contract_templates")
}

// ============================================================================
// ACADEMIC STRUCTURE
// ============================================================================

/// Rombel / kelas (e.g. "X IPA 1" semester 1 T.A. 2025/2026).
model Classroom {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  gradeLevel     Int       @map("grade_level") @db.SmallInt
  academicYearId String    @map("academic_year_id") @db.Uuid
  homeroomUserId String?   @map("homeroom_user_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  enrollments         Enrollment[]
  classSubjects       ClassSubject[]
  schedules           Schedule[]
  requirements        ScheduleRequirement[]
  homeroomAssignments HomeroomAssignment[]
  attendanceRecords   AttendanceRecord[]
  announcements       Announcement[]
  academicNotes       AcademicNote[]
  academicYear        AcademicYear          @relation(fields: [academicYearId], references: [id])

  @@unique([name, academicYearId])
  @@map("classrooms")
}

model PeriodTemplate {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gradeLevel     Int      @map("grade_level") @db.SmallInt
  academicYearId String   @map("academic_year_id") @db.Uuid
  dayStart       String   @map("day_start")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rows         PeriodRow[]
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([gradeLevel, academicYearId])
  @@map("period_templates")
}

model PeriodRow {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId  String     @map("template_id") @db.Uuid
  sortOrder   Int        @map("sort_order")
  kind        PeriodKind
  label       String
  durationMin Int        @map("duration_min")
  activeDays  Int[]      @default([]) @map("active_days")

  template       PeriodTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  entries        ScheduleEntry[]
  unavailability TeacherUnavailability[]

  @@unique([templateId, sortOrder])
  @@map("period_rows")
}

model HomeroomAssignment {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classroomId      String    @map("classroom_id") @db.Uuid
  teacherProfileId String    @map("teacher_profile_id") @db.Uuid
  academicYearId   String    @map("academic_year_id") @db.Uuid
  isActive         Boolean   @default(true) @map("is_active")
  assignedAt       DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)
  endedAt          DateTime? @map("ended_at") @db.Timestamptz(6)
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  classroom    Classroom      @relation(fields: [classroomId], references: [id])
  teacher      TeacherProfile @relation(fields: [teacherProfileId], references: [id])
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id])

  @@index([teacherProfileId, isActive])
  @@index([classroomId, academicYearId])
  @@map("homeroom_assignments")
}

/// Mata pelajaran milik sekolah ini.
model Subject {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String?
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  classSubjects   ClassSubject[]
  portfolios      StudentPortfolio[]
  scheduleEntries ScheduleEntry[]
  requirements    ScheduleRequirement[]
  academicNotes   AcademicNote[]

  @@map("subjects")
}

/// Penugasan guru ke kelas + mata pelajaran.
model ClassSubject {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classroomId      String  @map("classroom_id") @db.Uuid
  subjectId        String  @map("subject_id") @db.Uuid
  teacherProfileId String? @map("teacher_profile_id") @db.Uuid

  classroom Classroom       @relation(fields: [classroomId], references: [id])
  subject   Subject         @relation(fields: [subjectId], references: [id])
  teacher   TeacherProfile? @relation(fields: [teacherProfileId], references: [id])

  @@unique([classroomId, subjectId])
  @@map("class_subjects")
}

/// Siswa masuk ke kelas.
model Enrollment {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId String           @map("student_profile_id") @db.Uuid
  classroomId      String           @map("classroom_id") @db.Uuid
  enrolledAt       DateTime         @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  status           EnrollmentStatus @default(active)

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])
  classroom      Classroom      @relation(fields: [classroomId], references: [id])

  @@unique([studentProfileId, classroomId])
  @@map("enrollments")
}

model AttendanceRecord {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId String           @map("student_profile_id") @db.Uuid
  academicYearId   String           @map("academic_year_id") @db.Uuid
  classroomId      String           @map("classroom_id") @db.Uuid
  scheduleEntryId  String?          @map("schedule_entry_id") @db.Uuid
  attendanceDate   DateTime         @map("attendance_date") @db.Date
  status           AttendanceStatus
  lateMinutes      Int?             @map("late_minutes")
  notes            String?
  markedByUserId   String?          @map("marked_by_user_id") @db.Uuid
  updatedByUserId  String?          @map("updated_by_user_id") @db.Uuid
  updateReason     String?          @map("update_reason")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz(6)

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])
  classroom      Classroom      @relation(fields: [classroomId], references: [id])
  scheduleEntry  ScheduleEntry? @relation(fields: [scheduleEntryId], references: [id])
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id])
  markedBy       User?          @relation(fields: [markedByUserId], references: [id])
  updatedBy      User?          @relation("AttendanceUpdatedBy", fields: [updatedByUserId], references: [id])

  @@unique([studentProfileId, attendanceDate, scheduleEntryId])
  @@index([classroomId, attendanceDate])
  @@index([studentProfileId, academicYearId])
  @@map("attendance_records")
}

// ============================================================================
// STUDENT PORTFOLIO & ACHIEVEMENTS
// ============================================================================

/// Portfolio entries: projects, extracurriculars, certificates, personal development.
model StudentPortfolio {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId String        @map("student_profile_id") @db.Uuid
  title            String
  type             PortfolioType
  description      String?
  subjectId        String?       @map("subject_id") @db.Uuid
  startDate        DateTime?     @map("start_date") @db.Date
  endDate          DateTime?     @map("end_date") @db.Date
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  studentProfile StudentProfile        @relation(fields: [studentProfileId], references: [id])
  subject        Subject?              @relation(fields: [subjectId], references: [id])
  attachments    PortfolioAttachment[]

  @@map("student_portfolios")
}

model PortfolioAttachment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  portfolioId String   @map("portfolio_id") @db.Uuid
  fileUrl     String   @map("file_url")
  fileName    String   @map("file_name")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  portfolio StudentPortfolio @relation(fields: [portfolioId], references: [id])

  @@map("portfolio_attachments")
}

/// Academic and non-academic achievements with level and organizer info.
model StudentAchievement {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId String              @map("student_profile_id") @db.Uuid
  title            String
  category         AchievementCategory
  level            AchievementLevel?
  description      String?
  organizer        String?
  eventName        String?             @map("event_name")
  achievedAt       DateTime            @map("achieved_at") @db.Date
  rank             String?
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  studentProfile StudentProfile          @relation(fields: [studentProfileId], references: [id])
  attachments    AchievementAttachment[]

  @@map("student_achievements")
}

model AchievementAttachment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  achievementId String   @map("achievement_id") @db.Uuid
  fileUrl       String   @map("file_url")
  fileName      String   @map("file_name")
  mimeType      String   @map("mime_type")
  sizeBytes     Int      @map("size_bytes")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  achievement StudentAchievement @relation(fields: [achievementId], references: [id])

  @@map("achievement_attachments")
}

model AcademicNote {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentProfileId  String    @map("student_profile_id") @db.Uuid
  teacherProfileId  String?   @map("teacher_profile_id") @db.Uuid
  createdByUserId   String    @map("created_by_user_id") @db.Uuid
  subjectId         String?   @map("subject_id") @db.Uuid
  classroomId       String?   @map("classroom_id") @db.Uuid
  title             String
  body              String
  noteDate          DateTime  @default(now()) @map("note_date") @db.Date
  visibleToGuardian Boolean   @default(true) @map("visible_to_guardian")
  fileUrl           String?   @map("file_url")
  fileName          String?   @map("file_name")
  mimeType          String?   @map("mime_type")
  sizeBytes         Int?      @map("size_bytes")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  studentProfile StudentProfile  @relation(fields: [studentProfileId], references: [id])
  teacherProfile TeacherProfile? @relation(fields: [teacherProfileId], references: [id])
  createdBy      User            @relation("AcademicNoteCreatedBy", fields: [createdByUserId], references: [id])
  subject        Subject?        @relation(fields: [subjectId], references: [id])
  classroom      Classroom?      @relation(fields: [classroomId], references: [id])

  @@index([studentProfileId, noteDate])
  @@index([teacherProfileId, noteDate])
  @@index([classroomId, noteDate])
  @@index([createdByUserId])
  @@map("academic_notes")
}

// ============================================================================
// SCHEDULING
// ============================================================================

/// Physical rooms available for scheduling.
model Room {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique
  capacity    Int?
  description String?
  buildingName  String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  scheduleEntries ScheduleEntry[]
  requirements    ScheduleRequirement[]

  @@map("rooms")
}

/// Configurable lesson periods (e.g. 07:00–07:45).
/// Per-class-per-term timetable document.
model Schedule {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classroomId          String         @map("classroom_id") @db.Uuid
  academicYearId       String         @map("academic_year_id") @db.Uuid
  status               ScheduleStatus @default(draft)
  publishedAt          DateTime?      @map("published_at") @db.Timestamptz(6)
  archivedAt           DateTime?      @map("archived_at") @db.Timestamptz(6)
  copiedFromScheduleId String?        @map("copied_from_schedule_id") @db.Uuid
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?      @map("deleted_at") @db.Timestamptz(6)

  classroom    Classroom       @relation(fields: [classroomId], references: [id])
  copiedFrom   Schedule?       @relation("CopiedSchedule", fields: [copiedFromScheduleId], references: [id])
  copies       Schedule[]      @relation("CopiedSchedule")
  entries      ScheduleEntry[]
  academicYear AcademicYear    @relation(fields: [academicYearId], references: [id])

  @@unique([classroomId, academicYearId])
  @@map("schedules")
}

model ScheduleEntry {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId       String    @map("schedule_id") @db.Uuid
  subjectId        String    @map("subject_id") @db.Uuid
  teacherProfileId String    @map("teacher_profile_id") @db.Uuid
  roomId           String    @map("room_id") @db.Uuid
  dayOfWeek        Int?      @map("day_of_week") @db.SmallInt
  periodRowId      String?   @map("period_row_id") @db.Uuid
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  schedule  Schedule       @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  subject   Subject        @relation(fields: [subjectId], references: [id])
  teacher   TeacherProfile @relation(fields: [teacherProfileId], references: [id])
  room      Room           @relation(fields: [roomId], references: [id])
  periodRow PeriodRow?     @relation(fields: [periodRowId], references: [id])
  attendanceRecords AttendanceRecord[]

  @@index([teacherProfileId, dayOfWeek, periodRowId])
  @@index([roomId, dayOfWeek, periodRowId])
  @@map("schedule_entries")
}

// ============================================================================
// AUTO-SCHEDULING INPUTS
// ============================================================================

/// Defines how many sessions per week a subject needs in a class.
/// This is the input consumed by the greedy auto-scheduler.
model ScheduleRequirement {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classroomId      String   @map("classroom_id") @db.Uuid
  subjectId        String   @map("subject_id") @db.Uuid
  teacherProfileId String?  @map("teacher_profile_id") @db.Uuid
  roomId           String?  @map("room_id") @db.Uuid
  sessionsPerWeek  Int      @map("sessions_per_week") @db.SmallInt
  academicYearId   String   @map("academic_year_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  classroom    Classroom       @relation(fields: [classroomId], references: [id])
  subject      Subject         @relation(fields: [subjectId], references: [id])
  teacher      TeacherProfile? @relation(fields: [teacherProfileId], references: [id])
  room         Room?           @relation(fields: [roomId], references: [id])
  academicYear AcademicYear    @relation(fields: [academicYearId], references: [id])

  @@unique([classroomId, subjectId, academicYearId], map: "schedule_requirements_class_subject_year_key")
  @@map("schedule_requirements")
}

/// Teacher unavailability — slots where teacher CANNOT be assigned.
model TeacherUnavailability {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherProfileId String   @map("teacher_profile_id") @db.Uuid
  dayOfWeek        Int      @map("day_of_week") @db.SmallInt
  periodRowId      String   @map("period_row_id") @db.Uuid
  reason           String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  teacher   TeacherProfile @relation(fields: [teacherProfileId], references: [id])
  periodRow PeriodRow      @relation(fields: [periodRowId], references: [id])

  @@unique([teacherProfileId, dayOfWeek, periodRowId])
  @@map("teacher_unavailability")
}

// ============================================================================
// ANNOUNCEMENTS
// ============================================================================

model Announcement {
  id                String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String
  body              String
  audienceType      AnnouncementAudienceType @map("audience_type")
  targetGradeLevel  Int?                     @map("target_grade_level") @db.SmallInt
  targetClassroomId String?                  @map("target_classroom_id") @db.Uuid
  channels          AnnouncementChannel[]    @default([])
  status            AnnouncementStatus       @default(draft)
  scheduledAt       DateTime?                @map("scheduled_at") @db.Timestamptz(6)
  sentAt            DateTime?                @map("sent_at") @db.Timestamptz(6)
  pinned            Boolean                  @default(false)
  createdByUserId   String                   @map("created_by_user_id") @db.Uuid
  createdAt         DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?                @map("deleted_at") @db.Timestamptz(6)

  targetClassroom    Classroom?                @relation(fields: [targetClassroomId], references: [id])
  createdBy          User                      @relation("AnnouncementCreatedBy", fields: [createdByUserId], references: [id])
  attachments        AnnouncementAttachment[]
  recipients         AnnouncementRecipient[]
  deliveryLogs       AnnouncementDeliveryLog[]
  auditLogs          AnnouncementAuditLog[]
  notificationEvents NotificationEvent[]

  @@index([audienceType, targetGradeLevel])
  @@index([targetClassroomId])
  @@index([status, scheduledAt])
  @@index([pinned, createdAt])
  @@map("announcements")
}

model AnnouncementAttachment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  announcementId String   @map("announcement_id") @db.Uuid
  fileUrl        String   @map("file_url")
  fileName       String   @map("file_name")
  mimeType       String   @map("mime_type")
  sizeBytes      Int?     @map("size_bytes")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@map("announcement_attachments")
}

model AnnouncementRecipient {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  announcementId   String    @map("announcement_id") @db.Uuid
  studentProfileId String    @map("student_profile_id") @db.Uuid
  guardianId       String?   @map("guardian_id") @db.Uuid
  userId           String?   @map("user_id") @db.Uuid
  recipientKey     String    @map("recipient_key")
  name             String
  phone            String?
  email            String?
  readAt           DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  announcement   Announcement              @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  studentProfile StudentProfile            @relation(fields: [studentProfileId], references: [id])
  guardian       Guardian?                 @relation(fields: [guardianId], references: [id])
  user           User?                     @relation(fields: [userId], references: [id])
  deliveryLogs   AnnouncementDeliveryLog[]

  @@unique([announcementId, recipientKey])
  @@index([userId, readAt])
  @@index([studentProfileId, readAt])
  @@map("announcement_recipients")
}

model AnnouncementDeliveryLog {
  id             String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  announcementId String                     @map("announcement_id") @db.Uuid
  recipientId    String                     @map("recipient_id") @db.Uuid
  channel        AnnouncementChannel
  status         AnnouncementDeliveryStatus @default(pending)
  destination    String?
  provider       String?
  error          String?
  sentAt         DateTime?                  @map("sent_at") @db.Timestamptz(6)
  createdAt      DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  announcement Announcement          @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  recipient    AnnouncementRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([recipientId, channel])
  @@index([announcementId, channel, status])
  @@map("announcement_delivery_logs")
}

model AnnouncementTemplate {
  id        String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category  AnnouncementTemplateCategory
  title     String
  body      String
  isActive  Boolean                      @default(true) @map("is_active")
  createdAt DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?                    @map("deleted_at") @db.Timestamptz(6)

  @@index([category, isActive])
  @@map("announcement_templates")
}

model AnnouncementAuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  announcementId String?  @map("announcement_id") @db.Uuid
  actorUserId    String   @map("actor_user_id") @db.Uuid
  action         String
  metadata       Json?    @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  announcement Announcement? @relation(fields: [announcementId], references: [id], onDelete: SetNull)
  actor        User          @relation(fields: [actorUserId], references: [id])

  @@index([announcementId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("announcement_audit_logs")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model PushDeviceToken {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String             @map("user_id") @db.Uuid
  token      String             @unique
  platform   PushDevicePlatform @default(web)
  userAgent  String?            @map("user_agent")
  lastSeenAt DateTime           @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  revokedAt  DateTime?          @map("revoked_at") @db.Timestamptz(6)
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User                      @relation(fields: [userId], references: [id])
  deliveryLogs NotificationDeliveryLog[]

  @@index([userId, revokedAt])
  @@map("push_device_tokens")
}

model NotificationEvent {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  announcementId String?                 @map("announcement_id") @db.Uuid
  category       NotificationCategory    @default(system)
  eventType      String                  @map("event_type")
  priority       NotificationPriority    @default(normal)
  sourceType     NotificationSourceType? @map("source_type")
  sourceId       String?                 @map("source_id") @db.Uuid
  title          String
  body           String
  data           Json?                   @db.JsonB
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  announcement Announcement?           @relation(fields: [announcementId], references: [id], onDelete: SetNull)
  recipients   NotificationRecipient[]

  @@unique([eventType, sourceType, sourceId])
  @@index([announcementId])
  @@index([category, priority, createdAt])
  @@index([sourceType, sourceId])
  @@map("notification_events")
}

model NotificationRecipient {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId   String    @map("event_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  event        NotificationEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User                      @relation(fields: [userId], references: [id])
  deliveryLogs NotificationDeliveryLog[]

  @@unique([eventId, userId])
  @@index([userId, readAt, createdAt])
  @@map("notification_recipients")
}

model NotificationDeliveryLog {
  id                String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipientId       String                     @map("recipient_id") @db.Uuid
  pushDeviceTokenId String                     @map("push_device_token_id") @db.Uuid
  status            NotificationDeliveryStatus @default(queued)
  provider          String                     @default("fcm")
  providerMessageId String?                    @map("provider_message_id")
  error             String?
  sentAt            DateTime?                  @map("sent_at") @db.Timestamptz(6)
  createdAt         DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  recipient       NotificationRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  pushDeviceToken PushDeviceToken       @relation(fields: [pushDeviceTokenId], references: [id], onDelete: Cascade)

  @@unique([recipientId, pushDeviceTokenId])
  @@index([status, createdAt])
  @@index([recipientId])
  @@map("notification_delivery_logs")
}

// ───────────────────────────── Admissions / PPDB ─────────────────────────────

enum AdmissionSchoolLevel {
  preschool
  primary
  secondary

  @@map("admission_school_level")
}

enum AdmissionStudentCategory {
  kf_student
  non_kf
  not_applicable

  @@map("admission_student_category")
}

enum AdmissionKfStatusSource {
  system_derived
  manual_verified
  unverified
  not_applicable

  @@map("admission_kf_status_source")
}

/// Application workflow stage. Pre-school skips kf/test/offer stages (applied → accepted).
/// Semantic role that drives stage automation. Most stages are `generic`.
enum AdmissionStageRole {
  entry      // where new applications land
  test       // moving here prompts a test date
  offer      // unlocks parent package selection + invoices
  accepted   // offer accepted
  enrolled   // terminal success -> enrolledAt
  rejected   // terminal failure
  generic    // plain status step

  @@map("admission_stage_role")
}

/// A user-defined stage in the admission pipeline (configurable per tenant).
model AdmissionStageDef {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String             @unique                      // stable slug referenced by applications
  label       String                                          // admin-facing label
  publicLabel String?            @map("public_label")         // parent-facing label (falls back to label)
  role        AdmissionStageRole @default(generic)
  sortOrder   Int                @default(0) @map("sort_order")
  color       String?                                         // dot color (tailwind class or hex)
  isActive    Boolean            @default(true) @map("is_active")
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("admission_stage_defs")
}

enum AdmissionDocStatus {
  pending
  verified
  rejected

  @@map("admission_doc_status")
}

enum AdmissionDocType {
  kf_proof
  birth_certificate
  family_card
  photo
  test_result
  other

  @@map("admission_doc_type")
}

/// A PPDB applicant within this branch (tenant). Drives the admissions pipeline.
model AdmissionApplication {
  id             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationNo  String?                  @map("application_no")
  applicantName  String                   @map("applicant_name")
  applicantNik   String?                  @map("applicant_nik")
  birthDate      DateTime?                @map("birth_date") @db.Date
  gender         Gender?
  guardianName   String?                  @map("guardian_name")
  guardianPhone  String?                  @map("guardian_phone")
  guardianEmail  String?                  @map("guardian_email")

  schoolLevel    AdmissionSchoolLevel     @map("school_level")
  gradeLabel     String                   @map("grade_label")           // e.g. "Grade 7", "K1"
  academicYear   String                   @map("academic_year")         // e.g. "2026-2027"

  studentCategory AdmissionStudentCategory @default(not_applicable) @map("student_category")
  kfStatusSource  AdmissionKfStatusSource  @default(not_applicable) @map("kf_status_source")

  stageKey       String                   @default("applied") @map("stage_key")  // -> AdmissionStageDef.key
  testDate       DateTime?                @map("test_date") @db.Date
  testScore      Int?                     @map("test_score") @db.SmallInt
  resultDate     DateTime?                @map("result_date") @db.Date
  resultNotes    String?                  @map("result_notes")

  enrolledAt        DateTime?             @map("enrolled_at") @db.Timestamptz(6)
  studentProfileId  String?               @map("student_profile_id") @db.Uuid

  publicToken          String?            @unique @map("public_token")  // parent tracking link
  trackingCode         String?            @map("tracking_code")          // short access code for lookup-by-number
  selectedDevFeeTierId String?            @map("selected_dev_fee_tier_id") @db.Uuid
  formDataJson         Json?              @map("form_data_json")         // custom form-field answers
  blockedAt            DateTime?          @map("blocked_at") @db.Timestamptz(6)  // on-hold / blocked impediment
  blockReason          String?            @map("block_reason")
  letterIssuedAt       DateTime?          @map("letter_issued_at") @db.Timestamptz(6)  // acceptance letter
  letterUrl            String?            @map("letter_url")

  notes          String?
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?                @map("deleted_at") @db.Timestamptz(6)

  documents      AdmissionDocument[]
  invoices       AdmissionInvoice[]

  @@index([stageKey])
  @@index([academicYear, schoolLevel])
  @@map("admission_applications")
}

/// A document attached to an application (bukti lampiran / KK / akte / test result).
model AdmissionDocument {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String             @map("application_id") @db.Uuid
  documentType  AdmissionDocType   @map("document_type")
  requirementKey String?           @map("requirement_key")  // matches a form required-document key
  label         String?                                     // display label for the requirement
  fileUrl       String             @map("file_url")
  fileName      String             @map("file_name")
  status        AdmissionDocStatus @default(pending)
  notes         String?
  verifiedById  String?            @map("verified_by_id") @db.Uuid
  verifiedAt    DateTime?          @map("verified_at") @db.Timestamptz(6)
  uploadedAt    DateTime           @default(now()) @map("uploaded_at") @db.Timestamptz(6)

  application   AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("admission_documents")
}

// ───────────────────────── Admissions — Fees & Invoices ─────────────────────────

enum AdmissionFeeType {
  application
  test
  psychotest
  registration
  admission
  development
  tuition
  activities
  books
  uniform
  other

  @@map("admission_fee_type")
}

enum AdmissionPaymentTerm {
  one_time
  upon_registration
  upon_admission
  monthly
  per_term
  per_semester
  yearly

  @@map("admission_payment_term")
}

enum AdmissionInvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled

  @@map("admission_invoice_status")
}

/// Central per-grade / flat fee pricing for this branch + academic year.
model AdmissionFeeSchedule {
  id              String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolLevel     AdmissionSchoolLevel      @map("school_level")
  gradeLabel      String?                   @map("grade_label")        // null = applies to all grades in level
  studentCategory AdmissionStudentCategory? @map("student_category")   // null = all categories
  feeType         AdmissionFeeType          @map("fee_type")
  academicYear    String                    @map("academic_year")
  amount          Int                                                  // IDR (integer)
  paymentTerm     AdmissionPaymentTerm      @default(one_time) @map("payment_term")
  label           String?
  notes           String?
  isActive        Boolean                   @default(true) @map("is_active")
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?                 @map("deleted_at") @db.Timestamptz(6)

  @@index([academicYear, schoolLevel])
  @@map("admission_fee_schedules")
}

/// Duration-based development-fee packages (primary & secondary).
model AdmissionDevelopmentFeeTier {
  id              String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolLevel     AdmissionSchoolLevel      @map("school_level")
  studentCategory AdmissionStudentCategory? @map("student_category")   // null = all categories
  durationLabel   String                    @map("duration_label")     // e.g. "Gr 7–12 (6 yrs)"
  gradeFromLabel  String                    @map("grade_from_label")   // entry grade this tier applies to
  gradeToLabel    String?                   @map("grade_to_label")
  amount          Int                                                  // IDR
  paymentTerm     AdmissionPaymentTerm      @default(upon_registration) @map("payment_term")
  academicYear    String                    @map("academic_year")
  isActive        Boolean                   @default(true) @map("is_active")
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?                 @map("deleted_at") @db.Timestamptz(6)

  @@index([academicYear, schoolLevel])
  @@map("admission_development_fee_tiers")
}

/// An invoice issued against an application (test/admission/dev/tuition fees).
model AdmissionInvoice {
  id            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String                  @map("application_id") @db.Uuid
  invoiceNo     String                  @map("invoice_no")
  status        AdmissionInvoiceStatus  @default(draft)
  dueDate       DateTime?               @map("due_date") @db.Date
  totalAmount   Int                     @map("total_amount")
  paidAmount    Int                     @default(0) @map("paid_amount")
  paymentClaimedAt DateTime?            @map("payment_claimed_at") @db.Timestamptz(6)  // parent reported payment
  notes         String?
  issuedAt      DateTime                @default(now()) @map("issued_at") @db.Timestamptz(6)
  paidAt        DateTime?               @map("paid_at") @db.Timestamptz(6)
  createdAt     DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?               @map("deleted_at") @db.Timestamptz(6)

  application AdmissionApplication      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  items       AdmissionInvoiceItem[]

  @@index([applicationId])
  @@map("admission_invoices")
}

model AdmissionInvoiceItem {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId     String   @map("invoice_id") @db.Uuid
  description   String
  amount        Int
  feeType       AdmissionFeeType? @map("fee_type")
  periodLabel   String?  @map("period_label")
  feeScheduleId String?  @map("fee_schedule_id") @db.Uuid
  devFeeTierId  String?  @map("dev_fee_tier_id") @db.Uuid

  invoice AdmissionInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("admission_invoice_items")
}

/// A public PPDB registration form (one shareable link per academic year).
model PpdbForm {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token        String    @unique
  slug         String?   @unique                                            // custom short link
  academicYear String    @map("academic_year")
  title        String
  description  String?                                                       // form header intro text
  isOpen       Boolean   @default(true) @map("is_open")
  fieldsJson            Json @default("[]") @map("fields_json")             // applicant-info field definitions
  requiredDocumentsJson Json @default("[]") @map("required_documents_json") // document checklist
  paymentInstructions  String? @map("payment_instructions")                // manual/bank-transfer payment details
  acceptanceLetter     String? @map("acceptance_letter")                   // editable acceptance-letter body template
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("ppdb_forms")
}

/// Per-school-level admission settings (test gate, cut-off, available grades).
/// One row per school level (center = tenant, so these are this center's settings).
model AdmissionLevelSetting {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolLevel      AdmissionSchoolLevel @unique @map("school_level")
  hasTestGate      Boolean              @default(true) @map("has_test_gate")
  enrollmentCutoff DateTime?            @map("enrollment_cutoff") @db.Date
  gradeLabels      Json                 @default("[]") @map("grade_labels")
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("admission_level_settings")
}

model AcademicYear {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label     String // '2025/2026'
  semester  Int      @db.SmallInt
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  classrooms           Classroom[]
  attendanceRecords    AttendanceRecord[]
  periodTemplates      PeriodTemplate[]
  homeroomAssignments  HomeroomAssignment[]
  schedules            Schedule[]
  scheduleRequirements ScheduleRequirement[]

  @@unique([label, semester])
  @@map("academic_years")
}
