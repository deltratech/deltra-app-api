// ============================================================================
// LMS Multi-Tenant SaaS — Platform Schema (public)
// ----------------------------------------------------------------------------
// Stack    : NestJS + Prisma + PostgreSQL 16
// Strategy : Per-schema tenant isolation.
//            public  → SaaS operator / platform layer (us)
//            tenant_xxx → fully self-contained per-school schema
// Conventions : snake_case columns (@map), UUID PKs, soft delete (deleted_at)
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext]
}

// ============================================================================
// ENUMS
// ============================================================================

enum TenantType {
  school
  network

  @@map("tenant_type")
}

enum TenantStatus {
  active
  suspended
  trial

  @@map("tenant_status")
}

enum TenantPlan {
  starter
  standard
  pro

  @@map("tenant_plan")
}

// ============================================================================
// PLATFORM / OPERATOR LAYER
// ============================================================================

/// One row per school or yayasan network managed on this platform.
model Tenant {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String       @unique
  type      TenantType
  parentId  String?      @map("parent_id") @db.Uuid
  status    TenantStatus @default(trial)
  plan      TenantPlan   @default(starter)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt      @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?                    @map("deleted_at") @db.Timestamptz(6)

  settings TenantSettings?
  features TenantFeature[]

  @@map("tenants")
}

/// Branding, locale, and academic configuration per tenant.
model TenantSettings {
  tenantId       String   @id    @map("tenant_id") @db.Uuid
  logoUrl        String?         @map("logo_url")
  bgImageUrl     String?         @map("bg_image_url")
  primaryColor   String?         @map("primary_color")
  secondaryColor String?         @map("secondary_color")
  address        String?
  phone          String?
  email          String?
  npsn           String?
  accreditation  String?
  timezone       String   @default("Asia/Jakarta")
  locale         String   @default("id")
  academicYear   String?         @map("academic_year")
  semester       Int?            @db.SmallInt
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_settings")
}

/// Feature flags per tenant — controls module access without code deploys.
model TenantFeature {
  tenantId   String  @map("tenant_id") @db.Uuid
  featureKey String  @map("feature_key")
  enabled    Boolean @default(false)
  config     Json?   @db.JsonB

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@id([tenantId, featureKey])
  @@map("tenant_features")
}

// ============================================================================
// PLATFORM OPERATORS (us — SaaS staff only)
// ============================================================================

/// Accounts for the SaaS operator team. NOT for school users.
/// School users (admin, teacher, student, etc.) live in tenant_xxx.users.
model PlatformUser {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.Citext
  username     String?   @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  isSuperAdmin Boolean   @default(false) @map("is_super_admin")
  isActive     Boolean   @default(true)  @map("is_active")
  lastLoginAt  DateTime?                 @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at")    @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt      @map("updated_at")    @db.Timestamptz(6)
  deletedAt    DateTime?                 @map("deleted_at")    @db.Timestamptz(6)

  @@map("platform_users")
}

